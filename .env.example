# ── Database (PostgreSQL via Supabase / Neon) ────────────────
DATABASE_URL="postgresql://user:password@host:5432/memora_ai?schema=public"

# ── Supabase (pgvector) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── Authentication (JWT) ─────────────────────────────────────
JWT_SECRET="your-jwt-secret-here"

# ── Gemini AI ────────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"

# ── PayPal (Sandbox) ─────────────────────────────────────────
PAYPAL_CLIENT_ID="your-sandbox-client-id"
PAYPAL_SECRET="your-sandbox-secret"
PAYPAL_PRO_PLAN_ID="P-xxxxxxxxxxxxxxxxxxxxxxxx"
PAYPAL_ENTERPRISE_PLAN_ID="P-xxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_PAYPAL_CLIENT_ID="your-sandbox-client-id"
PAYPAL_WEBHOOK_ID="your-webhook-id"
